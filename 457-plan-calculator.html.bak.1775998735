    <script>
        function calculate() {
            const current = parseFloat(document.getElementById('current').value) || 0;
            const monthly = parseFloat(document.getElementById('monthly').value) || 0;
            const annualRate = parseFloat(document.getElementById('rate').value) / 100 || 0.07;
            const years = parseInt(document.getElementById('years').value) || 20;
            
            const monthlyRate = annualRate / 12;
            const months = years * 12;
            
            // Future value of current balance
            const futureValueCurrent = current * Math.pow(1 + monthlyRate, months);
            
            // Future value of monthly contributions (annuity)
            const futureValueContributions = monthly * ((Math.pow(1 + monthlyRate, months) - 1) / monthlyRate);
            
            const totalValue = futureValueCurrent + futureValueContributions;
            const totalContributions = current + (monthly * months);
            const totalGrowth = totalValue - totalContributions;
            
            let html = '<h3>Retirement Projection</h3>';
            html += '<div class="result-value">$' + totalValue.toFixed(2).toLocaleString() + '</div>';
            html += '<div class="result-detail"><strong>Starting Balance:</strong> $' + current.toLocaleString() + '</div>';
            html += '<div class="result-detail"><strong>Total Contributions:</strong> $' + totalContributions.toLocaleString() + '</div>';
            html += '<div class="result-detail"><strong>Investment Growth:</strong> $' + totalGrowth.toFixed(2).toLocaleString() + '</div>';
            html += '<div class="result-detail"><strong>Time Frame:</strong> ' + years + ' years</div>';
            html += '<div class="result-detail"><strong>Average Annual Return:</strong> ' + (annualRate * 100).toFixed(1) + '%</div>';
            
            // Add visual bar chart
            html += '<div class="chart-container">';
            html += '<div class="bar-chart">';
            const barHeight1 = (totalContributions / totalValue) * 100;
            const barHeight2 = (totalGrowth / totalValue) * 100;
            html += '<div class="bar" style="height:' + barHeight1 + '%">$' + (totalContributions/1000).toFixed(0) + 'k</div>';
            html += '<div class="bar" style="height:' + barHeight2 + '%">$' + (totalGrowth/1000).toFixed(0) + 'k</div>';
            html += '</div>';
            html += '<div style="display:flex; gap:0.5rem;">';
            html += '<div style="flex:1;" class="bar-label">Your Contributions</div>';
            html += '<div style="flex:1;" class="bar-label">Investment Growth</div>';
            html += '</div>';
            html += '</div>';
            
            html += '<p style="margin-top: 1.5rem; font-size: 0.95rem; color: #6e6e73;"><em>This projection assumes consistent returns and contributions. Actual results will vary based on market performance. Past performance does not guarantee future results.</em></p>';
            
            document.getElementById('result').innerHTML = html;
            document.getElementById('result').style.display = 'block';
        }
    </script>
<div class="calc-disclaimer" style="margin:1.5rem 0;padding:1rem 1.25rem;background:#fff8e1;border-left:4px solid #f59e0b;border-radius:0 8px 8px 0;font-size:.85rem;line-height:1.6;color:#92400e"><strong>⚠️ Disclaimer:</strong> This tool provides estimates for informational and educational purposes only. Results may not reflect actual values and should be verified independently. CalcLeap makes no warranties regarding the accuracy or completeness of any calculations. Use at your own discretion.</div>
<div style="background:var(--white,#fff);border:1px solid rgba(0,0,0,.08);border-radius:12px;padding:1.5rem;margin:1.5rem 0">
    <h3 style="font-size:.95rem;font-weight:700;margin-bottom:.75rem">📐 How We Calculate This</h3>
    <p style="font-size:.85rem;color:#424245;line-height:1.7;margin-bottom:.75rem">Our calculator uses the latest federal and state tax brackets published by the IRS and state revenue departments. We apply standard deductions, personal exemptions, and marginal tax rates for the current tax year.</p>
    <p style="font-size:.85rem;color:#424245;line-height:1.7">Results account for filing status, income level, and applicable credits. We update our tax data within 48 hours of any IRS or state announcements. For complex situations (AMT, self-employment, capital gains), consult a licensed CPA.</p>
</div>
<div style="background:#f5f5f7;border-radius:12px;padding:1.25rem;margin:1.25rem 0">
    <h4 style="font-size:.85rem;font-weight:700;margin-bottom:.5rem">📚 Sources & References</h4>
    <ul style="font-size:.82rem;color:#424245;line-height:1.8;padding-left:1.2rem;margin:0"><li><a href="https://www.irs.gov/newsroom/irs-provides-tax-inflation-adjustments" target="_blank" rel="noopener" style="color:#0071e3;text-decoration:none">IRS.gov — Tax Brackets & Rates</a></li><li><a href="https://www.irs.gov/publications/p17" target="_blank" rel="noopener" style="color:#0071e3;text-decoration:none">IRS Publication 17</a></li><li><a href="https://taxfoundation.org/data/all/state/" target="_blank" rel="noopener" style="color:#0071e3;text-decoration:none">Tax Foundation — State Tax Data</a></li></ul>
</div>


