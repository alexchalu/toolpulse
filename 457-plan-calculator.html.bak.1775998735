    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Display', 'Segoe UI', sans-serif; background: #fafafa; color: #1d1d1f; line-height: 1.6; }
        .header { background: white; border-bottom: 1px solid #e5e5e7; padding: 1rem 0; position: sticky; top: 0; z-index: 100; backdrop-filter: blur(20px); background: rgba(255,255,255,0.8); }
        .container { max-width: 1200px; margin: 0 auto; padding: 0 1rem; }
        .header h1 { font-size: 2rem; font-weight: 600; color: #1d1d1f; margin-bottom: 0.5rem; }
        .header p { color: #6e6e73; font-size: 1.1rem; }
        .main { padding: 3rem 0; }
        .calc-box { background: white; border-radius: 18px; padding: 2.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.06); margin-bottom: 2rem; border: 1px solid #e5e5e7; }
        .calc-box h2 { font-size: 1.75rem; font-weight: 600; margin-bottom: 1.5rem; color: #1d1d1f; }
        .input-group { margin-bottom: 1.5rem; }
        .input-group label { display: block; margin-bottom: 0.5rem; font-weight: 500; color: #1d1d1f; font-size: 1rem; }
        .input-group input, .input-group select { width: 100%; padding: 0.875rem 1rem; border: 1px solid #d2d2d7; border-radius: 12px; font-size: 1rem; transition: all 0.2s; background: white; }
        .input-group input:focus, .input-group select:focus { outline: none; border-color: #0071e3; box-shadow: 0 0 0 4px rgba(0,113,227,0.1); }
        .input-group small { color: #6e6e73; font-size: 0.9rem; }
        .calc-btn { background: #0071e3; color: white; border: none; padding: 1rem 2rem; font-size: 1.125rem; font-weight: 500; border-radius: 12px; cursor: pointer; width: 100%; transition: background 0.2s; }
        .calc-btn:hover { background: #0077ed; }
        .result-box { background: linear-gradient(135deg, #f5f9ff 0%, #e8f4ff 100%); border: 1px solid #0071e3; padding: 2rem; border-radius: 18px; margin-top: 1.5rem; display: none; }
        .result-box h3 { color: #0071e3; margin-bottom: 1.25rem; font-size: 1.5rem; font-weight: 600; }
        .result-value { font-size: 2.5rem; font-weight: 700; color: #0071e3; margin: 0.75rem 0; }
        .result-detail { margin: 0.75rem 0; color: #1d1d1f; font-size: 1.05rem; }
        .result-detail strong { font-weight: 600; }
        .chart-container { margin: 1.5rem 0; }
        .bar-chart { display: flex; gap: 0.5rem; align-items: flex-end; height: 200px; }
        .bar { flex: 1; background: linear-gradient(to top, #0071e3, #00a1ff); border-radius: 8px 8px 0 0; display: flex; flex-direction: column; justify-content: flex-end; align-items: center; padding: 0.5rem; color: white; font-weight: 600; font-size: 0.9rem; transition: transform 0.3s; }
        .bar:hover { transform: translateY(-5px); }
        .bar-label { margin-top: 0.5rem; font-size: 0.9rem; color: #6e6e73; text-align: center; }
        .info-section { background: white; border-radius: 18px; padding: 2.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.06); margin-bottom: 2rem; border: 1px solid #e5e5e7; }
        .info-section h3 { color: #1d1d1f; margin-bottom: 1rem; font-size: 1.5rem; font-weight: 600; }
        .info-section p { margin-bottom: 1rem; color: #1d1d1f; line-height: 1.7; }
        .info-section ul { margin-left: 1.5rem; margin-bottom: 1rem; }
        .info-section li { margin-bottom: 0.5rem; color: #1d1d1f; }
        .footer { background: #f5f5f7; padding: 2rem 0; text-align: center; border-top: 1px solid #e5e5e7; margin-top: 4rem; }
        .footer a { color: #0071e3; text-decoration: none; }
        @media (max-width: 768px) { .header h1 { font-size: 1.75rem; } .calc-box, .info-section { padding: 1.5rem; } }
    

/* === COMPREHENSIVE COMPONENT STYLES === */

/* Calc card (used by tax, mortgage, insurance pages) */
.calc-card,.calc-box,.calculator,.tool-container{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:2rem;box-shadow:var(--shadow);margin-bottom:1.5rem}
.calc-card h2,.calc-box h2{font-size:1.1rem;font-weight:700;letter-spacing:-.02em;margin-bottom:1.25rem}

/* Input groups and grids */
.input-grid,.form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1rem;margin-bottom:1rem}
.input-group{display:flex;flex-direction:column;gap:.3rem;margin-bottom:.75rem}
.input-group.full{grid-column:1/-1}
.input-group label,.field label,.label{font-size:.78rem;font-weight:600;color:var(--text-2);letter-spacing:.02em;text-transform:uppercase;display:block;margin-bottom:.3rem}
.input-group input,.input-group select,.input-group textarea,.field input,.field select{padding:.7rem .85rem;font-size:.95rem;font-family:var(--font);background:var(--bg);border:1px solid var(--border);border-radius:var(--r-xs);color:var(--text);outline:none;transition:all .2s;width:100%}
.input-group input:focus,.input-group select:focus,.field input:focus,.field select:focus{border-color:var(--accent);box-shadow:0 0 0 3px rgba(0,113,227,.1);background:var(--white)}

/* Field class (converter pages) */
.field{margin-bottom:1rem}
.row{display:flex;gap:.75rem;align-items:center}

/* Radio buttons */
.radio-group{display:flex;flex-wrap:wrap;gap:.5rem;margin-top:.25rem}
.radio-label{display:flex;align-items:center;gap:.4rem;font-size:.875rem;font-weight:500;color:var(--text-2);cursor:pointer;padding:.5rem .85rem;border:1px solid var(--border);border-radius:100px;transition:all .2s;text-transform:none;letter-spacing:normal}
.radio-label:hover{border-color:var(--accent);color:var(--accent)}
.radio-label input[type="radio"]{accent-color:var(--accent);width:16px;height:16px;margin:0}
.radio-label input[type="radio"]:checked + span,.radio-label:has(input:checked){border-color:var(--accent);background:var(--accent-bg);color:var(--accent)}

/* Buttons */
.calc-btn,.btn,.btn-primary,button[type="submit"]{display:inline-flex;align-items:center;justify-content:center;padding:.75rem 2rem;font-size:.95rem;font-weight:600;font-family:var(--font);background:var(--accent);color:#1d1d1f;border:none;border-radius:var(--r-sm);cursor:pointer;transition:all .2s;margin-top:.75rem;letter-spacing:-.01em}
.calc-btn:hover,.btn:hover,.btn-primary:hover{background:var(--accent-hover);box-shadow:0 4px 12px rgba(0,113,227,.3)}

/* Result boxes */
.result-box,.result,.results{background:var(--bg);border:1px solid var(--border);border-radius:var(--r);padding:1.5rem;margin-top:1.25rem}
.result-box h3,.result h3{font-size:1rem;font-weight:700;margin-bottom:.75rem;color:var(--text)}

/* Result grid (tax, insurance calculators) */
.result-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:.75rem;margin-bottom:1rem}
.result-card{background:var(--white);border:1px solid var(--border);border-radius:var(--r-sm);padding:1.25rem;text-align:center}
.result-card .label{font-size:.75rem;color:var(--text-3);text-transform:uppercase;letter-spacing:.04em;margin-bottom:.35rem}
.result-card .value{font-size:1.5rem;font-weight:800;letter-spacing:-.03em;color:var(--text)}
.result-card .value.green{color:#22c55e}

/* Result rows */
.result-row{display:flex;justify-content:space-between;align-items:center;padding:.7rem 0;border-bottom:1px solid var(--border)}
.result-row:last-child{border-bottom:none}
.result-detail{font-size:.85rem;color:var(--text-2)}
.result-value{font-size:.95rem;font-weight:700;color:var(--text)}
.result-item{display:flex;justify-content:space-between;align-items:center;padding:.65rem 0;border-bottom:1px solid var(--border)}
.result-item:last-child{border-bottom:none}

/* Stat cards (state tax pages) */
.stat-card,.stat{background:var(--white);border:1px solid var(--border);border-radius:var(--r-sm);padding:1.25rem;text-align:center}
.tax-stat{display:flex;justify-content:space-between;padding:.6rem 0;border-bottom:1px solid var(--border)}
.val{font-size:1.5rem;font-weight:800;letter-spacing:-.03em;color:var(--accent)}
.lbl{font-size:.78rem;color:var(--text-3);margin-top:.25rem}

/* Section */
.section,.info-section{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:1.75rem;margin-bottom:1.25rem;box-shadow:var(--shadow)}
.section h3,.info-section h3{font-size:1rem;font-weight:700;letter-spacing:-.015em;margin-bottom:1rem}

/* Container (fallback for old pages) */
.container,.main-content{max-width:var(--mw);margin:0 auto;padding:0}

/* Tool cards (converter index pages) */
.tool-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:.75rem;margin:1rem 0}
.tool-card{display:flex;align-items:center;gap:.75rem;padding:.85rem 1rem;background:var(--white);border:1px solid var(--border);border-radius:var(--r-sm);transition:all .2s;text-decoration:none;color:var(--text)}
.tool-card:hover{border-color:var(--accent);box-shadow:var(--shadow)}
.tool-card .icon{width:36px;height:36px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;background:var(--bg);border-radius:var(--r-xs);flex-shrink:0}
.tool-card h3{font-size:.875rem;font-weight:600;margin:0}
.tool-card p{font-size:.78rem;color:var(--text-3);margin:0}
.tool-content{flex:1}

/* Output area (dev tools) */
.output-area{background:var(--bg);border:1px solid var(--border);border-radius:var(--r-xs);padding:1rem;font-family:'SF Mono',SFMono-Regular,Menlo,Consolas,monospace;font-size:.85rem;min-height:120px;margin-top:1rem;white-space:pre-wrap;word-break:break-all;overflow:auto;max-height:400px}

/* Converter box */
.converter-box{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:2rem;box-shadow:var(--shadow);margin-bottom:1.5rem}
.swap-btn{background:var(--bg);border:1px solid var(--border);border-radius:50%;width:40px;height:40px;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:1.1rem;transition:all .2s;margin:0 auto}
.swap-btn:hover{border-color:var(--accent);color:var(--accent)}
.rate-display{text-align:center;font-size:.875rem;color:var(--text-2);padding:.75rem 0}
.conversion-table{margin-top:1rem}

/* Bar charts */
.bar{height:8px;border-radius:100px;overflow:hidden;background:rgba(0,0,0,.04);margin-top:.35rem}
.bar-fill{height:100%;border-radius:100px;transition:width .5s ease}
.bar-label{display:flex;justify-content:space-between;font-size:.78rem;color:var(--text-3);margin-bottom:.2rem}

/* Badge */
.badge{display:inline-block;font-size:.65rem;font-weight:700;padding:.2rem .6rem;border-radius:100px;text-transform:uppercase;letter-spacing:.04em}

/* Table wrapper */
.table-wrapper{overflow-x:auto;margin:1rem 0;border-radius:var(--r-sm);border:1px solid var(--border)}
.bracket-table{width:100%;border-collapse:collapse}

/* Rate cards */
.rate{font-size:.875rem;color:var(--text-2)}

/* Header (old pages fallback) */
.header{display:none} /* Old header hidden, replaced by .nav */

/* Sub text */
.sub{font-size:1rem;color:var(--text-2);line-height:1.5;margin-bottom:1.5rem;max-width:600px}

/* Ad placeholder — HIDE */
.ad-placeholder{display:none !important}

/* Hero override */
.hero{padding:.5rem 0 1rem}
.hero h1{font-size:2rem;font-weight:700;letter-spacing:-.03em;margin-bottom:.5rem}
.hero p{font-size:1rem;color:var(--text-2);max-width:600px}

/* FAQ items (old class) */
.faq-item{padding:.85rem 0;border-top:1px solid var(--border)}
.faq-item:first-child{border-top:none}

/* Toggle/tab buttons */
.toggle-btn,.tab-btn,.toggle-group button{padding:.5rem 1.25rem;font-size:.8rem;font-weight:600;font-family:var(--font);border:1px solid var(--border);border-radius:100px;background:var(--white);color:var(--text-3);cursor:pointer;transition:all .2s}
.toggle-btn.active,.tab-btn.active{background:var(--accent);color:#1d1d1f;border-color:var(--accent)}
.toggle-group{display:flex;gap:.5rem;margin-bottom:1rem}

/* Color helpers */
.green{color:#22c55e !important}
.red{color:#ef4444 !important}

/* Responsive */
@media(max-width:768px){
  .result-grid{grid-template-columns:1fr 1fr}
  .radio-group{flex-direction:column}
  .tool-grid{grid-template-columns:1fr}
  .row{flex-direction:column}
}
@media(max-width:480px){
  .result-grid{grid-template-columns:1fr}
}

